# ===== PostgreSQL =====
DATABASE_URL=postgres://USERNAME:PASSWORD@IP:PORT/zeabur
# Optional: force SSL for production DB providers
PG_SSL=false

# ===== TTRSS =====
TTRSS_ENDPOINT_URL=https://your-ttrss-instance.app/api/
TTRSS_USERNAME=admin
TTRSS_PASSWORD=your_password
# Supports multiple IDs separated by commas, e.g. 2,5,10
TTRSS_FEED_ID=2

# ===== OpenRouter =====
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_NAME=News-Reporter

# ===== App =====
ARTICLE_RETENTION_DAYS=7d
FETCH_INTERVAL_CRON=4h
CLEANUP_INTERVAL_CRON=7d
CRON_TIMEZONE=Asia/Hong_Kong
SITE_PASSWORD=your_password_here
CRON_SECRET=your_cron_secret

# ===== Firecrawl =====
FIRECRAWL_ON=false
FIRECRAWL_API_URL=https://your-firecrawl-instance.app
FIRECRAWL_API_KEY=your_firecrawl_api_key

